# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com/v2/{projectId}#clusters
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/talentiq?retryWrites=true&w=majority

# Flask Secret Key (for session management)
FLASK_SECRET_KEY=your_secret_key_here_change_this_in_production
